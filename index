    function showDiet() {
      const { dailyCals, protein, goal } = lastCalc;
      const plan = PLANS[goal];

      document.getElementById('diet-intro').textContent =
        plan.intro.replace('{cal}', dailyCals.toLocaleString()).replace('{p}', protein);

      const grid = document.getElementById('week-grid');
      grid.innerHTML = '';

      plan.days.forEach((d, i) => {
        const card = document.createElement('div');
        card.className = 'day-card' + (i === 0 ? ' open' : '');

        card.innerHTML = `
          <div class="day-header" onclick="toggleDay(this)">
            <span class="day-name">${d.day}</span>
            <span class="day-theme">${d.theme}</span>
            <span class="chevron">▼</span>
          </div>
          <div class="day-body">
            ${d.meals.map(m => `
              <div class="meal-row">
                <div class="meal-icon">${m.icon}</div>
                <div class="meal-info">
                  <div class="meal-type">${m.type}</div>
                  <div class="meal-name">${m.name}</div>
                  <div class="meal-cals">${m.cals}</div>
                </div>
              </div>`).join('')}
          </div>`;
        grid.appendChild(card);
      });

      const section = document.getElementById('diet-section');
      section.style.display = 'block';
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function toggleDay(header) {
      header.parentElement.classList.toggle('open');
    }
  </script>

