          { day:"Monday",    theme:"Balanced Start",   meals:[{icon:"🥣",type:"Breakfast",name:"Poha with peanuts + a boiled egg",cals:"~350 kcal"},{icon:"🍱",type:"Lunch",name:"Dal rice + sabzi + curd",cals:"~500 kcal"},{icon:"🥜",type:"Snack",name:"Banana + 15 mixed nuts",cals:"~190 kcal"},{icon:"🍛",type:"Dinner",name:"Roti + sabzi + a bowl of dal",cals:"~450 kcal"}]},
