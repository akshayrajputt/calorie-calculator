          { day:"Wednesday", theme:"Mid-week Reset",   meals:[{icon:"🥛",type:"Breakfast",name:"Smoothie bowl: oats, banana, milk, seeds",cals:"~380 kcal"},{icon:"🍲",type:"Lunch",name:"Chole + 2 rotis + onion salad",cals:"~510 kcal"},{icon:"🥒",type:"Snack",name:"Greek yoghurt + granola",cals:"~200 kcal"},{icon:"🥘",type:"Dinner",name:"Stir-fried veggies + tofu/chicken + rice (½ cup)",cals:"~450 kcal"}]},
          { day:"Thursday",  theme:"Classic Indian",   meals:[{icon:"🥣",type:"Breakfast",name:"Upma with veggies + coconut chutney",cals:"~360 kcal"},{icon:"🍱",type:"Lunch",name:"Rajma chawal + raita",cals:"~520 kcal"},{icon:"🥜",type:"Snack",name:"Roasted makhana (40g)",cals:"~160 kcal"},{icon:"🍛",type:"Dinner",name:"Paneer bhurji + 2 rotis",cals:"~470 kcal"}]},
